<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/playRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvPlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/play_title"
        android:textAppearance="@style/TextAppearance.Flames.Title" />

    <TextView
        android:id="@+id/btnOpenHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignTop="@id/tvPlayTitle"
        android:background="@drawable/bg_button_secondary"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="@string/history"
        android:textColor="@color/ocean_text"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/contentColumn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvPlayTitle"
        android:layout_marginTop="20dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter two names to reveal your FLAMES result."
            android:textAppearance="@style/TextAppearance.Flames.Subtitle" />

        <EditText
            android:id="@+id/etName1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:hint="@string/name_1_hint"
            android:inputType="textPersonName"
            android:textColor="@color/ocean_text"
            android:textColorHint="@color/ocean_text_muted" />

        <EditText
            android:id="@+id/etName2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="@string/name_2_hint"
            android:inputType="textPersonName"
            android:textColor="@color/ocean_text"
            android:textColorHint="@color/ocean_text_muted" />

        <LinearLayout
            android:id="@+id/actionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_calculate"
                android:background="@drawable/bg_button_primary"
                android:textColor="@color/ocean_surface"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:text="@string/btn_clear"
                android:background="@drawable/bg_button_secondary"
                android:textColor="@color/ocean_text"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvResultLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/result_label"
                android:textStyle="bold"
                android:textColor="@color/ocean_text_muted" />

            <TextView
                android:id="@+id/tvResultValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="—"
                android:textAppearance="@style/TextAppearance.Flames.Result" />

            <TextView
                android:id="@+id/tvResultDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/ocean_text"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
