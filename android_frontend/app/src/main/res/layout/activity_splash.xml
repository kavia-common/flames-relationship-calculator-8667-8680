<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ocean_primary"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/splashCenter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_title"
            android:textColor="@color/ocean_surface"
            android:textSize="44sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/splash_subtitle"
            android:textColor="@color/ocean_surface"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSplashFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Ocean Professional"
        android:textColor="@color/ocean_surface"
        android:textSize="12sp"
        android:alpha="0.8" />

</RelativeLayout>
